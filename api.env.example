# ══════════════════════════════════════════════════════
# Gemini Pixel Offer Claim Bot — Environment Configuration
# ══════════════════════════════════════════════════════

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=CHANGE_ME
ADMIN_USER_IDS=CHANGE_ME
BOT_TITLE=BDGeminBot
BOT_USERNAME=BDGeminBot

# ── Worker Backend ──
# "android" = ReDroid container on Linux VPS (recommended)
# "playwright" = browser-based (deprecated, less reliable)
WORKER_BACKEND=android

# ── Android Worker (VPS) ──
# Replace YOUR_VPS_IP after purchasing VPS tonight
ANDROID_WORKER_URL=http://YOUR_VPS_IP:8800
ANDROID_WORKER_API_KEY=CHANGE_ME
ADB_CONNECT_TIMEOUT_SEC=180
ADB_RECONNECT_INTERVAL_SEC=5
ADB_COMMAND_TIMEOUT_SEC=8

# ── Proxy (optional) ──
# BrightData residential proxy for Google login (disabled by default)
# Uncomment to enable proxy:
# PROXY_URL=http://user:pass@proxy-host:proxy-port
PROXY_URL=

# ── Login Settings ──
LOGIN_MAX_RETRIES=0
DEVICE_PROMPT_TIMEOUT=90
LOGIN_NAVIGATION_TIMEOUT_MS=90000
